# Copy this to .env and fill in values for local development (DO NOT commit secrets)
# GitHub Models API token used by agent.py
GITHUB_TOKEN=

# Use either a service account JSON path OR a user OAuth token file (pick one)
# Service account JSON file path for server-to-server authentication
GOOGLE_APPLICATION_CREDENTIALS=
# OR
# OAuth user token JSON file created by OAuth flow
GOOGLE_CALENDAR_TOKEN_FILE=

# Calendar ID to operate on (defaults to primary)
GOOGLE_CALENDAR_ID=primary

# Optional default timezone for naive datetimes
GOOGLE_CALENDAR_TIMEZONE=UTC
