GOOGLE_APPLICATION_CREDENTIALS=env/google.json         # path to service account JSON for Google APIs (non-key value)
GOOGLE_TOKEN_FILE=env/token.json           # path to OAuth token json (used by calendar, gmail, etc)
GOOGLE_DEFAULT_EMAIL=                    # default email account to use for Gmail and Calendar operations
GOOGLE_CALENDAR_ID=primary               # calendar ID for reading/writing events
GOOGLE_CALENDAR_TIMEZONE=Asia/Hong_Kong  # timezone for calendar events (e.g. Asia/Hong_Kong)
DEFAULT_TIMEZONE=Asia/Hong_Kong          # fallback timezone for date/time operations
DISCORD_BOT_TOKEN=                       # your Discord bot token (keep secret)
DISCORD_USER_ID=                         # limit bot to this user ID (optional)
ACTIVATION_WORD=hey                      # word/phrase to activate the agent ("hey" in your .env)
ACTIVATION_TIMEOUT=60                    # seconds before an inactive session auto-leaves (optional)
ENABLE_SPEECH_ON_START=true              # enable speech input when app starts
LANGSEARCH_KEY=                          # API key for langsearch service (if used)

MODEL_PROVIDER=ollama                  # high-level provider selector (openai/ollama/gemini/etc)
OLLAMA_MODEL=gpt-oss:120b                # model name to use with Ollama (e.g. "gpt-oss:120b")
OLLAMA_NUM_CTX=32768                     # context window size for Ollama models
OLLAMA_ENDPOINT=https://ollama.com       # custom Ollama endpoint if not default
GEMINI_API_KEY=                          # API key for Google Gemini provider (keep secret)
OLLAMA_API_KEY=                          # API key for Ollama provider (keep secret)
GITHUB_TOKEN=                            # token for GitHub skill (keep secret)

PINECONE_API_KEY=                     # key for Pinecone vector database (keep secret)
PINECONE_NAMESPACE=agent              # namespace to use for Pinecone index
PINECONE_OPENAI_EMBED_MODEL=text-embedding-3-small  # default embedding model name
PINECONE_DIMENSION=1536               # vector dimension (match embedder)
PINECONE_INDEX_NAME=agent-memory      # name of Pinecone index to query